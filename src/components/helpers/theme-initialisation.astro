---
import { storageKey } from "@/helpers/theme";
---

<script is:inline define:vars={{ storageKey }}>
	(() => {
		/**
		 * Determine whether the system settings currently prefer dark mode.
		 *
		 * @returns  {boolean}
		 */
		function systemPrefersDark() {
			return window.matchMedia("(prefers-color-scheme: dark)").matches;
		}

		/**
		 * Read the stored theme from localStorage, returning null if absent or
		 * unavailable.
		 *
		 * @returns  {string|null}
		 */
		function getStoredTheme() {
			try {
				return localStorage.getItem(storageKey);
			} catch {
				return null;
			}
		}

		/**
		 * Combine any stored theme and system preference to determine the
		 * appropriate current theme. Stored themes take precedence.
		 *
		 * @returns  {"light"|"dark"}
		 */
		function getCurrentTheme() {
			const storedTheme = getStoredTheme();

			if (storedTheme !== null) {
				return storedTheme;
			}

			if (systemPrefersDark()) {
				return "dark";
			}

			return "light";
		}

		document.documentElement.classList.toggle("dark", getCurrentTheme() === "dark");
	})();
</script>
